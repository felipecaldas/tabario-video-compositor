    "max_words_visible": 6
  },
  "transitions": {
    "preferred": ["soft_cut", "slide_push", "scale_push"],
    "intensity": "standard",
    "color_wipe_max": 1
  },
  "motion": {
    "energy": "medium",
    "pace": "medium",
    "ken_burns_strength": 0.4
  },
  "grade": "neutral",
  "overlays": {
    "density": "standard",
