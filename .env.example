# Server
PORT=9312
DATA_SHARED_BASE=/data/shared

# Supabase (same anon key used by edit-videos)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_STORAGE_BUCKET=videos

# OpenRouter (LLM for manifest generation)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=google/gemini-2.5-flash

# edit-videos service URL (faster-whisper ASR for word-level captions)
VIDEO_MERGER_URL=http://video-merger:8000

# Webhook — mirrors VIDEO_COMPLETED_N8N_WEBHOOK_URL from edit-videos
VIDEO_COMPLETED_N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/your-webhook-id
