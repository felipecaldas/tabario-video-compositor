{
  "name": "tabario-video-compositor",
  "version": "0.1.0",
  "description": "Tabario video composition and rendering service — Remotion-based brand-driven video assembly",
  "main": "dist/api/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --exec ts-node src/api/server.ts",
    "start": "node dist/api/server.js",
    "test": "jest --testPathPattern=tests/unit --coverage",
    "test:coverage": "jest --testPathPattern=tests/unit --coverage",
    "test:integration": "jest --testPathPattern=tests/integration --runInBand",
    "lint": "eslint 'src/**/*.ts' 'remotion/**/*.tsx'",
    "format": "prettier --write 'src/**/*.ts' 'remotion/**/*.tsx'"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "@supabase/supabase-js": "^2.43.0",
    "express": "^4.18.3",
    "openai": "^4.47.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "nodemon": "^3.1.3",
    "prettier": "^3.2.5",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "5.4.5"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", {"isolatedModules": true}]
    },
    "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json"],
    "roots": ["<rootDir>/tests"],
    "testMatch": [
      "<rootDir>/tests/**/*.test.ts",
      "<rootDir>/tests/**/*.test.tsx"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/node_modules/",
      "<rootDir>/tests/helpers/"
    ],
    "testTimeout": 30000,
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "remotion/**/*.ts",
      "remotion/**/*.tsx",
      "!src/api/server.ts",
      "!remotion/index.ts",
      "!remotion/Root.tsx",
      "!**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 90,
        "statements": 90,
        "branches": 80,
        "functions": 90
      }
    }
  }
}
